{
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "oxlint": "^1.51.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-node": "^5.3.0"
  },
  "scripts": {
    "dev": "vite",
    "fetch": "vite-node src/fetch.ts",
    "test": "vite-node src/tests/run_all_tests.ts",
    "test:old": "vite-node src/test.ts",
    "check": "tsc --noEmit && oxlint && biome format --write src/*.ts src/*/*.ts && vite-node src/lyn_rummy/run_all_tests.ts && vite-node src/tests/run_all_tests.ts",
    "build": "vite build",
    "lint": "oxlint",
    "format": "biome format --write src/*.ts src/*/*.ts"
  },
  "dependencies": {
    "npm": "^11.10.1"
  }
}
